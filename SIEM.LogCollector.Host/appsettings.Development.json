{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "KafkaConsumer": {
    "BootstrapServers": "localhost:9093",
    "Topic": "kaspersky-logs",
    "GroupId": "log-processor-group"
  },
  "Elasticsearch": {
    "Url": "http://localhost:9200",
    "Index": "kaspersky-logs"
  },
  "Filter": {
    "IgnoredPatterns": [ "ignore", "debug" ]
  }
}